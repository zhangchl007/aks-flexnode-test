# Copy to .env and adjust values before running scripts.
SUBSCRIPTION_ID=""
TENANT_ID=""
LOCATION_AKS="eastus2"
LOCATION_GPU="westus2"

# Existing cluster A
CLUSTER_A_RG="aks-test-rg"
CLUSTER_A_NAME="aks-storage-test"

# New cluster B
CLUSTER_B_RG="aksflex-gpu-test-eastus2-rg"
CLUSTER_B_NAME="aksflex-gpu-test-b"
CLUSTER_B_NODE_SIZE="standard_d2s_v3"
CLUSTER_B_NODE_COUNT="1"
KUBERNETES_VERSION="1.34.8"
CLUSTER_B_SERVICE_CIDR="10.200.0.0/16"
CLUSTER_B_DNS_SERVICE_IP="10.200.0.10"

# GPU host
GPU_RG="aksflex-a10-gpu-rg"
GPU_VM_NAME="aksflexgpu-a10-01"
GPU_VM_SIZE="Standard_NV36ads_A10_v5"
GPU_QUOTA_LOCAL_NAME="Standard NVADSA10v5 Family vCPUs"
# Plain Ubuntu 22.04 Gen2 — NO pre-installed NVIDIA drivers (avoids 595.71.05 conflict)
# NVads A10 v5 requires NVIDIA GRID R570.211.01 (.run installer); ubuntu-hpc image is incompatible
GPU_IMAGE="Canonical:0001-com-ubuntu-server-jammy:22_04-lts-gen2:latest"
GPU_ADMIN_USER="azureuser"
GPU_SSH_KEY="${HOME}/.ssh/id_rsa.pub"
PROVISION_GPU_VM="true"
USE_SPOT_GPU_VM="true"
SPOT_EVICTION_POLICY="Delete"
SPOT_MAX_PRICE="-1"
SPOT_GPU_QUOTA_LOCAL_NAME=""

# AKS Flex Node
AGENT_POOL_NAME="aksflexnodes"
TARGET_HOST="azureuser@52.233.95.129"
SETUP_BOOTSTRAP_RBAC="false"
MANAGED_IDENTITY_CLIENT_ID=""
FLEXNODE_JOIN_AUTH_MODE="bootstrap-token"
AZ_VM_RUN_COMMAND_TIMEOUT="10m"

# GPU Operator. The Ubuntu HPC image already includes the NVIDIA driver, so the
# operator must only install cluster GPU components and must not install drivers.
GPU_OPERATOR_DRIVER_ENABLED="false"
GPU_OPERATOR_DEVICE_PLUGIN_ENABLED="true"
GPU_OPERATOR_GFD_ENABLED="true"
GPU_OPERATOR_TOOLKIT_ENABLED="false"
GPU_OPERATOR_DRIVER_INSTALL_DIR="/run/nvidia/driver"
